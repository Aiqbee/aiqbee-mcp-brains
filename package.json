{
  "name": "aiqbee-brain-manager",
  "displayName": "Aiqbee Brain Manager",
  "description": "Access and manage Aiqbee Brains from within VS Code. Browse brains, view neurons, and configure MCP connections for AI coding assistants.",
  "version": "0.1.0",
  "publisher": "aiqbee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiqbee/platform-vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "aiqbee",
    "brain",
    "mcp",
    "knowledge",
    "ai"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "icon": "media/aiqbee-icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiqbee-sidebar",
          "title": "Aiqbee",
          "icon": "media/aiqbee-sidebar.svg"
        }
      ]
    },
    "views": {
      "aiqbee-sidebar": [
        {
          "type": "webview",
          "id": "aiqbee.brainManagerView",
          "name": "Brain Manager"
        }
      ]
    },
    "commands": [
      {
        "command": "aiqbee.signIn",
        "title": "Aiqbee: Sign In"
      },
      {
        "command": "aiqbee.signOut",
        "title": "Aiqbee: Sign Out"
      },
      {
        "command": "aiqbee.refresh",
        "title": "Aiqbee: Refresh Brains"
      },
      {
        "command": "aiqbee.addMcpConnection",
        "title": "Aiqbee: Add MCP Connection"
      }
    ],
    "configuration": {
      "title": "Aiqbee Brain Manager",
      "properties": {
        "aiqbee.environment": {
          "type": "string",
          "default": "production",
          "enum": [
            "development",
            "production"
          ],
          "description": "API environment to connect to."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile:prod",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "node esbuild.js",
    "compile:webview": "cd webview-ui && npm run build",
    "compile:dev": "node esbuild.js --mode=eudev && cd webview-ui && npm run build -- --mode eudev",
    "compile:prod": "node esbuild.js --mode=euprod && cd webview-ui && npm run build -- --mode euprod",
    "watch": "node esbuild.js --watch",
    "package:dev": "npm run compile:dev && vsce package",
    "package:prod": "npm run compile:prod && vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
